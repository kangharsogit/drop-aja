# Public URL where this app is accessible
PUBLIC_URL=https://your-domain.com

# Timezone
TZ=Asia/Jakarta

# Optional: Cloudflare Turnstile (anti-bot for /upload form)
# Leave empty to disable. Get keys at https://dash.cloudflare.com → Turnstile (free, unlimited)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
